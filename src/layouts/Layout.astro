---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'SageCG — Boutique Venture Studio & Startup Operators',
  description = 'Operating since 1998, SageCG is a national boutique venture studio building companies that earn their keep. A focused portfolio across GovTech, EdTech, and B2B SaaS.',
  ogImage = '/og.png',
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-4J0FWODC6W"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-4J0FWODC6W');
    </script>

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:site_name" content="SageCG" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      '@id': 'https://www.sagecg.com/#organization',
      name: 'Sage Consulting Group',
      alternateName: ['SageCG', 'Sage CG'],
      url: 'https://www.sagecg.com',
      logo: 'https://www.sagecg.com/og.png',
      image: 'https://www.sagecg.com/og.png',
      description,
      foundingDate: '1998',
      founder: {
        '@type': 'Person',
        name: 'Rob Pfleghardt',
        jobTitle: 'Founder & Operator',
        url: 'https://www.sagecg.com/contact#founder',
      },
      address: {
        '@type': 'PostalAddress',
        streetAddress: '504 Mashie Drive',
        addressLocality: 'Vienna',
        addressRegion: 'VA',
        postalCode: '22180',
        addressCountry: 'US',
      },
      contactPoint: [{
        '@type': 'ContactPoint',
        contactType: 'general',
        email: 'hello@sagecg.com',
      }, {
        '@type': 'ContactPoint',
        contactType: 'careers',
        email: 'careers@sagecg.com',
      }],
      sameAs: ['https://github.com/rob637'],
    })}></script>
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      '@id': 'https://www.sagecg.com/#website',
      url: 'https://www.sagecg.com',
      name: 'SageCG',
      publisher: { '@id': 'https://www.sagecg.com/#organization' },
      inLanguage: 'en-US',
    })}></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
