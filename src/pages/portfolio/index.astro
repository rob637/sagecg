---
import Layout from '../../layouts/Layout.astro';
import PortfolioCard from '../../components/PortfolioCard.astro';
import { getCollection } from 'astro:content';

const companies = (await getCollection('portfolio')).sort(
  (a, b) => a.data.order - b.data.order
);

const active = companies.filter((c) => c.data.status === 'active');
const building = companies.filter((c) => c.data.status === 'building');
const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  numberOfItems: companies.length,
  itemListElement: companies.map((entry, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `https://www.sagecg.com/portfolio/${entry.id}/`,
    name: entry.data.name,
  })),
};
---
<Layout
  title="Portfolio — SageCG Venture Studio"
  description="The full SageCG portfolio: LeaderReps LLC, CBR Labs LLC, VoraPrep LLC, ToothHound, The Longest Table, and NFL Fantasy Auction Draft."
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListLd)}></script>
  <!-- Hero -->
  <section class="border-b border-[var(--color-rule)]">
    <div class="mx-auto max-w-6xl px-6 pt-20 pb-16">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-muted)]">Portfolio</p>
      <h1 class="mt-4 font-display text-5xl sm:text-6xl tracking-tight leading-[1.02] max-w-3xl">
        Everything we’re building, in one place.
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-[var(--color-ink)]/75 leading-relaxed">
        Three companies are in market. Three apps are in build. All of them share a back office, a set of principles, and a long-term mindset.
      </p>
    </div>
  </section>

  <!-- Active -->
  <section class="mx-auto max-w-6xl px-6 pt-12 pb-12">
    <div class="flex items-baseline justify-between">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-muted)]">In Market</p>
      <p class="font-mono text-[11px] text-[var(--color-muted)]">{active.length} / {companies.length}</p>
    </div>
    <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {active.map((entry) => <PortfolioCard entry={entry} />)}
    </div>
  </section>

  <!-- Building -->
  <section class="mx-auto max-w-6xl px-6 pt-12 pb-24">
    <div class="flex items-baseline justify-between">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-muted)]">In build</p>
      <p class="font-mono text-[11px] text-[var(--color-muted)]">{building.length} / {companies.length}</p>
    </div>
    <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {building.map((entry) => <PortfolioCard entry={entry} />)}
    </div>
  </section>
</Layout>
