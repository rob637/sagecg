---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async () => {
  const entries = await getCollection('portfolio');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}) satisfies GetStaticPaths;

const { entry } = Astro.props;
const { Content } = await render(entry);
const { data } = entry;

const statusLabel: Record<string, string> = {
  active: 'In Market',
  building: 'In build',
  concept: 'Concept',
  archived: 'Archived',
};

// Related (everything else, max 3)
const others = (await getCollection('portfolio'))
  .filter((c) => c.id !== entry.id)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);

// Only show meta fields that have values
const meta = [
  { label: 'Status', value: statusLabel[data.status] ?? data.status },
  data.stage ? { label: 'Stage', value: data.stage } : null,
  data.founded ? { label: 'Founded', value: data.founded } : null,
].filter(Boolean) as { label: string; value: string }[];

const pageUrl = `https://www.sagecg.com/portfolio/${entry.id}/`;
const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.sagecg.com/' },
    { '@type': 'ListItem', position: 2, name: 'Portfolio', item: 'https://www.sagecg.com/portfolio/' },
    { '@type': 'ListItem', position: 3, name: data.name, item: pageUrl },
  ],
};
const companyLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: data.legalName || data.name,
  alternateName: data.name,
  description: data.summary,
  url: data.url || pageUrl,
  parentOrganization: { '@id': 'https://www.sagecg.com/#organization' },
};
if (data.founded) companyLd.foundingDate = String(data.founded);
---
<Layout
  title={`${data.name} — SageCG Portfolio`}
  description={data.summary}
  ogImage={data.ogImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(companyLd)}></script>
  <article>
    <!-- Header -->
    <section class="border-b border-[var(--color-rule)]">
      <div class="mx-auto max-w-4xl px-6 pt-12 pb-14">
        <a
          href="/portfolio"
          class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-muted)] hover:text-[var(--color-accent)] transition-colors"
        >
          ← Portfolio
        </a>

        <div class="mt-8 flex items-center gap-2.5">
          <span
            class="inline-block h-2 w-2 rounded-full"
            style={`background: ${data.accent ?? 'var(--color-accent)'}`}
          ></span>
          <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)]">
            {statusLabel[data.status]} · {data.sector}
          </span>
        </div>

        <h1 class="mt-4 font-display text-5xl sm:text-6xl tracking-tight leading-[1.02]">{data.name}</h1>
        {data.legalName && data.legalName !== data.name && (
          <p class="mt-2 text-sm text-[var(--color-muted)] font-mono">{data.legalName}</p>
        )}

        {(data.url || data.secondaryUrl) && (
          <div class="mt-5 flex flex-wrap gap-x-8 gap-y-3 font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-muted)]">
            {data.url && (
              <div class="flex items-center gap-3">
                {data.secondaryUrl && <span class="opacity-40">Public</span>}
                <a 
                  href={data.url} 
                  target="_blank" 
                  rel="noopener"
                  class="text-[var(--color-ink)]/85 hover:text-[var(--color-accent)] transition-colors underline underline-offset-4 decoration-[var(--color-rule)]"
                >
                  {new URL(data.url).hostname.replace('www.', '')}
                </a>
              </div>
            )}
            {data.secondaryUrl && (
              <div class="flex items-center gap-3">
                <span class="opacity-40">{data.secondaryUrl.includes('admin') || data.secondaryUrl.includes('arena') ? 'Private' : 'Secondary'}</span>
                <a 
                  href={data.secondaryUrl} 
                  target="_blank" 
                  rel="noopener"
                  class="text-[var(--color-ink)]/85 hover:text-[var(--color-accent)] transition-colors underline underline-offset-4 decoration-[var(--color-rule)]"
                >
                  {new URL(data.secondaryUrl).hostname.replace('www.', '')}{new URL(data.secondaryUrl).pathname !== '/' ? new URL(data.secondaryUrl).pathname : ''}
                </a>
              </div>
            )}
          </div>
        )}

        <p class="mt-7 font-display text-2xl sm:text-3xl text-[var(--color-ink)]/85 italic max-w-2xl leading-snug">
          {data.tagline}
        </p>

        <dl class="mt-10 flex flex-wrap gap-x-12 gap-y-6 border-t border-[var(--color-rule)] pt-8">
          {meta.map((m) => (
            <div>
              <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)]">{m.label}</dt>
              <dd class="mt-1.5 text-sm text-[var(--color-ink)]/85">{m.value}</dd>
            </div>
          ))}
          {data.url && (
            <div>
              <dt class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)]">Website</dt>
              <dd class="mt-1.5 text-sm">
                <a
                  class="text-[var(--color-ink)]/85 hover:text-[var(--color-accent)] underline underline-offset-4 decoration-[var(--color-rule)] hover:decoration-[var(--color-accent)] transition-colors"
                  href={data.url}
                  target="_blank"
                  rel="noopener"
                >
                  Visit site →
                </a>
              </dd>
            </div>
          )}
        </dl>
      </div>
    </section>

    <!-- Body -->
    <section class="mx-auto max-w-3xl px-6 pt-14 pb-20">
      <div class="prose-content">
        <Content />
      </div>
    </section>
  </article>

  <!-- Related -->
  <section class="border-t border-[var(--color-rule)] bg-white/40">
    <div class="mx-auto max-w-6xl px-6 py-16">
      <p class="font-mono text-[11px] uppercase tracking-[0.22em] text-[var(--color-muted)]">Also in the portfolio</p>
      <div class="mt-6 grid gap-5 sm:grid-cols-3">
        {others.map((c) => (
          <a
            href={`/portfolio/${c.id}/`}
            class="group block rounded-lg border border-[var(--color-rule)] bg-[var(--color-paper)] p-5 hover:border-[var(--color-ink)]/40 transition-colors"
          >
            <h3 class="font-display text-xl tracking-tight group-hover:text-[var(--color-accent)] transition-colors">{c.data.name}</h3>
            <p class="mt-1.5 text-sm text-[var(--color-muted)] leading-relaxed">{c.data.tagline}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style is:global>
  .prose-content {
    color: var(--color-ink);
    font-size: 1.0625rem;
    line-height: 1.75;
  }
  .prose-content h2 {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    letter-spacing: -0.02em;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .prose-content h2:first-child { margin-top: 0; }
  .prose-content h3 {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    margin-top: 1.75rem;
    margin-bottom: 0.5rem;
  }
  .prose-content p { margin: 1rem 0; }
  .prose-content ul, .prose-content ol { margin: 1rem 0; padding-left: 1.25rem; }
  .prose-content ul { list-style: disc; }
  .prose-content ol { list-style: decimal; }
  .prose-content li { margin: 0.35rem 0; }
  .prose-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-rule);
  }
  .prose-content a:hover { text-decoration-color: var(--color-accent); }
  .prose-content strong { font-weight: 600; }
  .prose-content em { font-family: var(--font-serif); font-style: italic; }
</style>
