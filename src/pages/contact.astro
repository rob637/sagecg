---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Contact — Sage CG Venture Studio"
  description="Get in touch with Sage Consulting Group — partnerships, press, careers in the portfolio, or just to say hello."
>
  <section class="mx-auto max-w-3xl px-6 pt-20 pb-24">
    <p class="font-mono text-xs uppercase tracking-[0.22em] text-[var(--color-muted)]">Contact</p>
    <h1 class="mt-4 font-display text-5xl sm:text-6xl tracking-tight">Say hello.</h1>
    <p class="mt-6 text-lg text-[var(--color-ink)]/75 leading-relaxed max-w-2xl">
      The studio is small and we read everything that comes in. Tell us what you're working on and we'll point you to the right person — or write back ourselves.
    </p>

    <div class="mt-12 grid sm:grid-cols-2 gap-6">
      <a
        href="mailto:hello@sagecg.com"
        class="block rounded-xl border border-[var(--color-rule)] p-6 hover:border-[var(--color-ink)]/40 transition-colors"
      >
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-muted)]">General</p>
        <p class="mt-2 font-display text-2xl">hello@sagecg.com</p>
        <p class="mt-2 text-sm text-[var(--color-muted)]">Partnerships, press, or a friendly note.</p>
      </a>
      <a
        href="mailto:careers@sagecg.com"
        class="block rounded-xl border border-[var(--color-rule)] p-6 hover:border-[var(--color-ink)]/40 transition-colors"
      >
        <p class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-muted)]">Careers</p>
        <p class="mt-2 font-display text-2xl">careers@sagecg.com</p>
        <p class="mt-2 text-sm text-[var(--color-muted)]">Roles across the portfolio companies.</p>
      </a>
    </div>
  </section>
</Layout>
