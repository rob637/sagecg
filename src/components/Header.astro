---
const path = Astro.url.pathname;
const isActive = (p: string) => path === p || (p !== '/' && path.startsWith(p));

const links = [
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
---
<header class="border-b border-[var(--color-rule)] bg-[var(--color-paper)]/90 backdrop-blur supports-[backdrop-filter]:bg-[var(--color-paper)]/70 sticky top-0 z-40">
  <div class="mx-auto max-w-6xl px-6 h-[72px] flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group">
      <span class="font-display text-2xl sm:text-3xl tracking-tight leading-none">Sage<span class="text-[var(--color-accent)]">CG</span></span>
      <span class="hidden sm:inline font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)] border border-[var(--color-rule)] px-1.5 py-0.5 rounded-sm">
        Venture Studio
      </span>
    </a>
    <nav class="flex items-center gap-1 text-sm">
      {links.map((l) => (
        <a
          href={l.href}
          class:list={[
            'px-3 py-2 rounded-md transition-colors',
            isActive(l.href)
              ? 'text-[var(--color-ink)]'
              : 'text-[var(--color-muted)] hover:text-[var(--color-ink)]',
          ]}
        >
          {l.label}
        </a>
      ))}
    </nav>
  </div>
</header>
