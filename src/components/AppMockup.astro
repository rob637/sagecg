---
// On-brand vector "app preview" mockups, themed per company accent.
// Pure SVG — crisp at any size, no external assets, no runtime cost.
interface Props {
  id: string;
  name: string;
  accent?: string;
  url?: string;
}

const { id, name, accent = '#b45309', url } = Astro.props;

const ink = '#0c0a09';
const muted = '#78716c';
const rule = '#e7e5e4';
const panel = '#ffffff';
const soft = '#f5f5f4';

const host = url ? url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/.*$/, '') : 'app';

// Helper: ring dash for a circle of radius r at given percent.
const ring = (r: number, pct: number) => {
  const c = 2 * Math.PI * r;
  return { dash: (c * pct).toFixed(1), gap: c.toFixed(1), c };
};

let inner = '';

if (id === 'leaderreps') {
  const rings = [
    { cx: 170, label: 'Lead Yourself', pct: 0.72 },
    { cx: 360, label: 'Lead Others', pct: 0.55 },
    { cx: 550, label: 'Lead the Work', pct: 0.4 },
  ];
  inner = `
    <text x="40" y="108" font-family="Inter,sans-serif" font-size="15" font-weight="600" fill="${ink}">This week's reps</text>
    <text x="680" y="108" text-anchor="end" font-family="Inter,sans-serif" font-size="13" fill="${accent}" font-weight="600">9-day streak</text>
    ${rings
      .map((rg) => {
        const { dash, gap } = ring(40, rg.pct);
        return `
      <circle cx="${rg.cx}" cy="190" r="40" fill="none" stroke="${rule}" stroke-width="11"/>
      <circle cx="${rg.cx}" cy="190" r="40" fill="none" stroke="${accent}" stroke-width="11" stroke-linecap="round"
        stroke-dasharray="${dash} ${gap}" transform="rotate(-90 ${rg.cx} 190)"/>
      <text x="${rg.cx}" y="197" text-anchor="middle" font-family="Inter,sans-serif" font-size="18" font-weight="700" fill="${ink}">${Math.round(
          rg.pct * 100
        )}</text>
      <text x="${rg.cx}" y="262" text-anchor="middle" font-family="Inter,sans-serif" font-size="12" fill="${muted}">${rg.label}</text>`;
      })
      .join('')}
    ${[0, 1, 2]
      .map(
        (i) => `
      <rect x="40" y="${308 + i * 44}" width="640" height="34" rx="8" fill="${soft}"/>
      <circle cx="62" cy="${325 + i * 44}" r="7" fill="${accent}"/>
      <path d="M58 ${325 + i * 44} l3 3 l6 -7" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
      <rect x="82" y="${319 + i * 44}" width="${[300, 360, 250][i]}" height="7" rx="3.5" fill="${ink}" opacity="0.55"/>
      <rect x="82" y="${331 + i * 44}" width="${[180, 140, 210][i]}" height="6" rx="3" fill="${muted}" opacity="0.4"/>`
      )
      .join('')}`;
} else if (id === 'cbr-labs') {
  inner = `
    <rect x="250" y="96" width="220" height="300" rx="20" fill="${soft}" stroke="${rule}" stroke-width="2"/>
    <rect x="266" y="120" width="188" height="240" rx="6" fill="${panel}" stroke="${rule}"/>
    <circle cx="360" cy="378" r="9" fill="none" stroke="${muted}" stroke-width="2"/>
    <!-- camera removed -->
    <circle cx="360" cy="110" r="5" fill="${rule}"/>
    <line x1="351" y1="101" x2="369" y2="119" stroke="${accent}" stroke-width="3" stroke-linecap="round"/>
    <text x="360" y="180" text-anchor="middle" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${ink}">CAMERA</text>
    <text x="360" y="200" text-anchor="middle" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${ink}">+ MIC REMOVED</text>
    <rect x="300" y="224" width="120" height="1" fill="${rule}"/>
    <text x="360" y="256" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="11" fill="${muted}">NIST 800-171</text>
    <!-- certificate badge -->
    <circle cx="360" cy="306" r="30" fill="none" stroke="${accent}" stroke-width="2.5"/>
    <path d="M347 306 l9 9 l17 -19" stroke="${accent}" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="40" y="108" font-family="Inter,sans-serif" font-size="15" font-weight="600" fill="${ink}">Serial-numbered certificate</text>
    <text x="40" y="150" font-family="JetBrains Mono,monospace" font-size="12" fill="${muted}">CBR-2025-0481</text>
    <text x="620" y="108" text-anchor="end" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${accent}">Verified</text>`;
} else if (id === 'voraprep') {
  inner = `
    <text x="40" y="106" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${muted}">Question 24 / 70</text>
    <text x="680" y="106" text-anchor="end" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${accent}">CPA · REG</text>
    <rect x="40" y="120" width="640" height="6" rx="3" fill="${rule}"/>
    <rect x="40" y="120" width="220" height="6" rx="3" fill="${accent}"/>
    <rect x="40" y="146" width="430" height="9" rx="4.5" fill="${ink}" opacity="0.7"/>
    <rect x="40" y="166" width="360" height="9" rx="4.5" fill="${ink}" opacity="0.55"/>
    ${[0, 1, 2, 3]
      .map((i) => {
        const sel = i === 1;
        return `
      <rect x="40" y="${204 + i * 46}" width="500" height="36" rx="9" fill="${sel ? accent : soft}" ${
          sel ? '' : `stroke="${rule}"`
        }/>
      <circle cx="64" cy="${222 + i * 46}" r="8" fill="none" stroke="${sel ? '#fff' : muted}" stroke-width="2"/>
      ${sel ? `<circle cx="64" cy="${222 + i * 46}" r="3.5" fill="#fff"/>` : ''}
      <rect x="84" y="${218 + i * 46}" width="${[300, 240, 330, 200][i]}" height="7" rx="3.5" fill="${
          sel ? '#fff' : ink
        }" opacity="${sel ? '0.95' : '0.5'}"/>`;
      })
      .join('')}
    <!-- score gauge -->
    <circle cx="612" cy="300" r="54" fill="none" stroke="${rule}" stroke-width="12"/>
    <circle cx="612" cy="300" r="54" fill="none" stroke="${accent}" stroke-width="12" stroke-linecap="round"
      stroke-dasharray="${ring(54, 0.78).dash} ${ring(54, 0.78).gap}" transform="rotate(-90 612 300)"/>
    <text x="612" y="298" text-anchor="middle" font-family="Inter,sans-serif" font-size="26" font-weight="700" fill="${ink}">78%</text>
    <text x="612" y="318" text-anchor="middle" font-family="Inter,sans-serif" font-size="11" fill="${muted}">Ready score</text>`;
} else if (id === 'kindkudos') {
  inner = `
    <rect x="210" y="120" width="300" height="200" rx="18" fill="${soft}" stroke="${rule}"/>
    <rect x="210" y="120" width="300" height="46" rx="18" fill="${accent}"/>
    <rect x="210" y="150" width="300" height="16" fill="${accent}"/>
    <text x="234" y="149" font-family="Inter,sans-serif" font-size="14" font-weight="600" fill="#fff">Anonymous kudos</text>
    <rect x="234" y="190" width="252" height="8" rx="4" fill="${ink}" opacity="0.6"/>
    <rect x="234" y="210" width="220" height="8" rx="4" fill="${ink}" opacity="0.45"/>
    <rect x="234" y="230" width="180" height="8" rx="4" fill="${ink}" opacity="0.45"/>
    <!-- AI shield -->
    <path d="M360 270 l26 8 v16 c0 16 -12 26 -26 32 c-14 -6 -26 -16 -26 -32 v-16 z" fill="none" stroke="${accent}" stroke-width="2.5"/>
    <path d="M349 296 l8 8 l15 -16" stroke="${accent}" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
    <text x="40" y="108" font-family="Inter,sans-serif" font-size="15" font-weight="600" fill="${ink}">AI screened before delivery</text>
    <text x="620" y="108" text-anchor="end" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${accent}">Kind ✓</text>
    <text x="360" y="372" text-anchor="middle" font-family="Inter,sans-serif" font-size="12" fill="${muted}">Safe · Anonymous · Genuine</text>`;
} else if (id === 'longest-table') {
  const seats = 8;
  inner = `
    <text x="40" y="108" font-family="Inter,sans-serif" font-size="15" font-weight="600" fill="${ink}">Vienna · Block Dinner</text>
    <text x="680" y="108" text-anchor="end" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${accent}">48 RSVP'd</text>
    <!-- long table -->
    <rect x="120" y="210" width="480" height="60" rx="10" fill="${soft}" stroke="${rule}" stroke-width="2"/>
    ${Array.from({ length: seats })
      .map((_, i) => {
        const x = 150 + i * 60;
        return `<circle cx="${x}" cy="188" r="12" fill="${accent}" opacity="${0.55 + (i % 3) * 0.15}"/>
                <circle cx="${x}" cy="292" r="12" fill="${accent}" opacity="${0.5 + (i % 2) * 0.2}"/>`;
      })
      .join('')}
    <!-- map pin -->
    <path d="M360 330 c-16 0 -28 12 -28 28 c0 20 28 44 28 44 c0 0 28 -24 28 -44 c0 -16 -12 -28 -28 -28 z" fill="none" stroke="${accent}" stroke-width="2.5"/>
    <circle cx="360" cy="358" r="9" fill="${accent}"/>
    <text x="40" y="430" font-family="Inter,sans-serif" font-size="12" fill="${muted}">Strangers in. Neighbors out.</text>`;
} else if (id === 'toothhound') {
  const { dash, gap } = ring(60, 0.87);
  inner = `
    <text x="40" y="108" font-family="Inter,sans-serif" font-size="15" font-weight="600" fill="${ink}">Today's Hunt Score</text>
    <text x="680" y="108" text-anchor="end" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${accent}">Venice Beach, FL</text>
    <!-- hunt score gauge -->
    <circle cx="200" cy="250" r="60" fill="none" stroke="${rule}" stroke-width="14"/>
    <circle cx="200" cy="250" r="60" fill="none" stroke="${accent}" stroke-width="14" stroke-linecap="round"
      stroke-dasharray="${dash} ${gap}" transform="rotate(-90 200 250)"/>
    <text x="200" y="258" text-anchor="middle" font-family="Inter,sans-serif" font-size="40" font-weight="700" fill="${ink}">87</text>
    <text x="200" y="338" text-anchor="middle" font-family="Inter,sans-serif" font-size="12" fill="${muted}">Prime · outgoing tide</text>
    <!-- tide curve -->
    <text x="420" y="170" font-family="Inter,sans-serif" font-size="12" fill="${muted}">Tide window</text>
    <path d="M420 250 q40 -60 80 0 t80 0 t80 0" fill="none" stroke="${accent}" stroke-width="2.5"/>
    <line x1="420" y1="250" x2="660" y2="250" stroke="${rule}" stroke-width="1"/>
    <!-- tooth -->
    <path d="M500 312 c-10 0 -16 8 -16 20 c0 22 12 40 16 48 c4 -8 16 -26 16 -48 c0 -12 -6 -20 -16 -20 z" fill="${accent}" opacity="0.9"/>
    <text x="540" y="356" font-family="Inter,sans-serif" font-size="13" font-weight="600" fill="${ink}">Megalodon · 2.4"</text>`;
} else if (id === 'football-draft') {
  inner = `
    <text x="40" y="108" font-family="Inter,sans-serif" font-size="15" font-weight="600" fill="${ink}">On the block</text>
    <rect x="560" y="92" width="120" height="30" rx="15" fill="${soft}" stroke="${rule}"/>
    <text x="620" y="112" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="14" font-weight="700" fill="${accent}">00:08</text>
    <!-- team card -->
    <rect x="40" y="140" width="640" height="80" rx="12" fill="${soft}" stroke="${rule}"/>
    <circle cx="92" cy="180" r="24" fill="${accent}" opacity="0.18"/>
    <text x="92" y="187" text-anchor="middle" font-family="Inter,sans-serif" font-size="18" font-weight="700" fill="${accent}">KC</text>
    <text x="134" y="174" font-family="Inter,sans-serif" font-size="17" font-weight="600" fill="${ink}">Kansas City</text>
    <text x="134" y="198" font-family="Inter,sans-serif" font-size="12" fill="${muted}">Proj. 11.4 wins · top tier</text>
    <text x="660" y="190" text-anchor="end" font-family="Inter,sans-serif" font-size="30" font-weight="700" fill="${ink}">$74</text>
    <!-- bid rows -->
    ${[
      ['Manager A', '$72'],
      ['Manager D', '$68'],
      ['Suggested', '$76'],
    ]
      .map((row, i) => {
        const sug = i === 2;
        return `
      <rect x="40" y="${244 + i * 46}" width="640" height="36" rx="9" fill="${sug ? accent : panel}" stroke="${
          sug ? accent : rule
        }"/>
      <text x="64" y="${267 + i * 46}" font-family="Inter,sans-serif" font-size="13" font-weight="${
          sug ? '600' : '500'
        }" fill="${sug ? '#fff' : ink}">${row[0]}</text>
      <text x="656" y="${267 + i * 46}" text-anchor="end" font-family="JetBrains Mono,monospace" font-size="14" font-weight="700" fill="${
          sug ? '#fff' : accent
        }">${row[1]}</text>`;
      })
      .join('')}`;
} else {
  inner = `<text x="360" y="240" text-anchor="middle" font-family="Inter,sans-serif" font-size="16" fill="${muted}">${name}</text>`;
}

const svg = `
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 720 460" role="img" aria-label="${name} product preview" width="100%" height="100%">
  <rect x="0.5" y="0.5" width="719" height="459" rx="18" fill="${panel}" stroke="${rule}"/>
  <rect x="0" y="0" width="720" height="62" rx="18" fill="${soft}"/>
  <rect x="0" y="44" width="720" height="18" fill="${soft}"/>
  <circle cx="34" cy="31" r="5.5" fill="${accent}"/>
  <circle cx="54" cy="31" r="5.5" fill="${rule}"/>
  <circle cx="74" cy="31" r="5.5" fill="${rule}"/>
  <rect x="150" y="18" width="420" height="26" rx="13" fill="${panel}" stroke="${rule}"/>
  <text x="360" y="35" text-anchor="middle" font-family="JetBrains Mono,monospace" font-size="12" fill="${muted}">${host}</text>
  <line x1="0" y1="62" x2="720" y2="62" stroke="${rule}"/>
  <g transform="translate(0,8)">${inner}</g>
</svg>`;
---
<div
  class="relative overflow-hidden rounded-2xl border border-[var(--color-rule)]"
  style={`background: linear-gradient(135deg, ${accent}0d, ${accent}05);`}
>
  <div class="p-5 sm:p-8">
    <div class="mx-auto max-w-2xl drop-shadow-[0_18px_40px_-20px_rgba(12,10,9,0.35)]" set:html={svg} />
  </div>
</div>
<style>
  div :global(svg) { display: block; }
</style>
