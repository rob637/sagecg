---
import type { CollectionEntry } from 'astro:content';

interface Props {
  entry: CollectionEntry<'portfolio'>;
}

const { entry } = Astro.props;
const { data } = entry;
const statusLabel: Record<string, string> = {
  active: 'In Market',
  building: 'In build',
  concept: 'Concept',
  archived: 'Archived',
};
---
<div
  class="group relative block rounded-xl border border-[var(--color-rule)] bg-[var(--color-paper)] p-6 transition-all hover:-translate-y-0.5 hover:shadow-[0_12px_40px_-12px_rgba(12,10,9,0.18)] hover:border-[var(--color-ink)]/25"
  style={`--card-accent: ${data.accent ?? 'var(--color-accent)'}`}
>
  <span
    class="absolute left-0 top-6 bottom-6 w-[3px] rounded-full opacity-70 group-hover:opacity-100 transition-opacity"
    style="background: var(--card-accent)"
  ></span>

  <div class="flex items-center justify-between gap-3">
    <h3 class="font-display text-xl sm:text-2xl tracking-tight group-hover:text-[var(--color-accent)] transition-colors">
      <a href={`/portfolio/${entry.id}/`} class="after:absolute after:inset-0">
        {data.name}
      </a>
    </h3>
    <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)] whitespace-nowrap">
      {statusLabel[data.status] ?? data.status}
    </span>
  </div>

  {(data.url || data.secondaryUrl) && (
    <div class="relative z-10 mt-1 flex flex-wrap gap-x-4 gap-y-1">
      {data.url && (
        <a 
          href={data.url}
          target="_blank"
          rel="noopener"
          class="inline-block font-mono text-[10px] text-[var(--color-muted)] tracking-wider opacity-60 hover:opacity-100 hover:text-[var(--color-accent)] transition-all line-clamp-1"
        >
          {data.url.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '')}
        </a>
      )}
      {data.secondaryUrl && (
        <a 
          href={data.secondaryUrl}
          target="_blank"
          rel="noopener"
          class="inline-block font-mono text-[10px] text-[var(--color-muted)] tracking-wider opacity-60 hover:opacity-100 hover:text-[var(--color-accent)] transition-all line-clamp-1 border-l border-[var(--color-rule)] pl-4"
        >
          {data.secondaryUrl.replace(/^https?:\/\/(www\.)?/, '').replace(/\/$/, '')}
        </a>
      )}
    </div>
  )}

  <p class="mt-2 text-[15px] text-[var(--color-ink)]/85 italic font-display leading-snug">{data.tagline}</p>
  <p class="mt-3 text-sm text-[var(--color-muted)] leading-relaxed">{data.summary}</p>

  <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1 text-[11px] text-[var(--color-muted)] font-mono">
    <span>{data.sector}</span>
    {data.founded && <span class="text-[var(--color-muted)]/70">est. {data.founded}</span>}
  </div>
</div>
