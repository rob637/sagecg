---
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-rule)] mt-24">
  <div class="mx-auto max-w-6xl px-6 py-12 grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
    <div class="lg:col-span-2">
      <a href="/" class="font-display text-2xl tracking-tight">Sage<span class="text-[var(--color-accent)]">CG</span></a>
      <p class="mt-3 text-sm text-[var(--color-muted)] max-w-sm">
        A venture studio building a small portfolio of useful software companies. Founded out of Sage Consulting Group.
      </p>
    </div>
    <div>
      <h4 class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-muted)]">Studio</h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="hover:text-[var(--color-accent)]" href="/portfolio">Portfolio</a></li>
        <li><a class="hover:text-[var(--color-accent)]" href="/about">About</a></li>
        <li><a class="hover:text-[var(--color-accent)]" href="/contact">Contact</a></li>
      </ul>
    </div>
    <div>
      <h4 class="font-mono text-xs uppercase tracking-[0.18em] text-[var(--color-muted)]">Elsewhere</h4>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="hover:text-[var(--color-accent)]" href="#">LinkedIn</a></li>
        <li><a class="hover:text-[var(--color-accent)]" href="#">GitHub</a></li>
        <li><a class="hover:text-[var(--color-accent)]" href="/rss.xml">RSS</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-[var(--color-rule)]">
    <div class="mx-auto max-w-6xl px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 text-xs text-[var(--color-muted)]">
      <p>© {year} Sage Consulting Group. All rights reserved.</p>
      <p class="font-mono">sagecg.com</p>
    </div>
  </div>
</footer>
