---
const year = new Date().getFullYear();
---
<footer class="border-t border-[var(--color-rule)]">
  <div class="mx-auto max-w-6xl px-6 pt-20 pb-12">
    <a href="/" class="block font-display text-7xl sm:text-8xl lg:text-9xl tracking-tight leading-none hover:opacity-80 transition-opacity">
      Sage<span class="text-[var(--color-accent)] italic">CG</span>
    </a>
    <p class="mt-6 max-w-xl text-[var(--color-muted)] leading-relaxed">
      A small venture studio building the companies it wants to run. Operated by Sage Consulting Group since 1998.
    </p>
  </div>
  <div class="border-t border-[var(--color-rule)]">
    <div class="mx-auto max-w-6xl px-6 py-10 grid gap-10 sm:grid-cols-2 lg:grid-cols-12">
      <div class="lg:col-span-6">
        <h4 class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)]">Get in touch</h4>
        <ul class="mt-3 space-y-2">
          <li><a class="hover:text-[var(--color-accent)] transition-colors" href="mailto:hello@sagecg.com">hello@sagecg.com</a></li>
          <li><a class="hover:text-[var(--color-accent)] transition-colors" href="mailto:careers@sagecg.com">careers@sagecg.com</a></li>
          <li><a class="hover:text-[var(--color-accent)] transition-colors" href="/contact#founder">Meet the founder →</a></li>
        </ul>
      </div>
      <div class="lg:col-span-3">
        <h4 class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)]">Studio</h4>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a class="hover:text-[var(--color-accent)] transition-colors" href="/portfolio">Portfolio</a></li>
          <li><a class="hover:text-[var(--color-accent)] transition-colors" href="/about">About</a></li>
          <li><a class="hover:text-[var(--color-accent)] transition-colors" href="/contact">Contact</a></li>
        </ul>
      </div>
      <div class="lg:col-span-3 text-sm text-[var(--color-muted)]">
        <h4 class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-muted)]">Mailing</h4>
        <p class="mt-3 leading-relaxed">
          Sage Consulting Group<br />504 Mashie Drive, Vienna, VA 22180
        </p>
      </div>
    </div>
  </div>
  <div class="border-t border-[var(--color-rule)]">
    <div class="mx-auto max-w-6xl px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2 text-xs text-[var(--color-muted)]">
      <p>© {year} Sage Consulting Group. All rights reserved.</p>
      <p class="font-mono">sagecg.com</p>
    </div>
  </div>
</footer>
